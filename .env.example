VITE_APP_NAME=SafeVision AI

# Backend
# Use a unique 32+ character value in real deployments.
JWT_SECRET_KEY=replace-this-with-a-unique-32-character-minimum-secret
DATABASE_URL=sqlite:///./safevision.db
CORS_ORIGINS=http://localhost:8501,http://localhost:5173

# Docker Compose PostgreSQL
POSTGRES_DB=safevision
POSTGRES_USER=safevision
POSTGRES_PASSWORD=replace-this-dev-password
